# Local storage
GEO_DATA_DIR=./data
GEO_DATABASE_PATH=./data/geo_optimizer.db

# Claude Code executable and timeout for live audits
GEO_CLAUDE_BIN=claude
GEO_AUDIT_TIMEOUT_SECONDS=1800

# Additional Claude Code arguments separated by spaces.
# Keep empty unless you understand the permissions being granted.
GEO_CLAUDE_EXTRA_ARGS=
